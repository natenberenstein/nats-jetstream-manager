{
  "name": "nats-jetstream-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky"
  },
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0"
  },
  "lint-staged": {
    "backend/**/*.ts": [
      "prettier --write",
      "eslint --fix --config backend/eslint.config.mjs"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored --config frontend/eslint.config.mjs"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
