# Server
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Auth
AUTH_ENABLED=true
USER_AUTH_ENABLED=true
ADMIN_TOKEN=
VIEWER_TOKEN=

# Database
# DATABASE_TYPE: "sqlite" (default) or "postgres"
DATABASE_TYPE=sqlite

# SQLite settings (used when DATABASE_TYPE=sqlite)
DATABASE_PATH=./data/nats_manager.db

# PostgreSQL settings (used when DATABASE_TYPE=postgres)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=
# DATABASE_NAME=nats_manager
# DATABASE_SSL=false

# Connection Management
MAX_CONNECTIONS=10
CONNECTION_TIMEOUT=300

# Metrics
METRICS_COLLECTION_INTERVAL=30
METRICS_RETENTION_HOURS=24

# Health Checks
HEALTH_CHECK_INTERVAL=30
HEALTH_RETENTION_DAYS=7

# Sessions
SESSION_TTL_HOURS=168
INVITE_TTL_HOURS=72

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
